# === NAS-SMB (für x-file-cifs URIs zu Sonos) ===
# IP/Hostname des NAS, Share-Name
NAS_SMB_HOST=192.168.0.7
NAS_SMB_SHARE=Musik
# Lokaler Mount-Punkt des NAS-Shares
NAS_MUSIC_PATH=/tmp/nas-musik

# === Sonos CLI ===
# Pfad zum sonos-CLI binary
# Standard: https://github.com/iancleary/sonos CLI
SONOS_CLI=/home/openclaw/go/bin/sonos
